# Example environment variable overrides
# Copy this to .env and fill in real values (never commit .env)

# ---- Active environment ----
# Options: development | production
# ENV_FOR_DYNACONF=development

# ---- Server ----
# HUNYUAN3D__SERVER__PORT=8000
# HUNYUAN3D__SERVER__HOST=0.0.0.0

# ---- Model ----
# HUNYUAN3D__MODEL__PRETRAINED_ID=tencent/Hunyuan3D-2
# HUNYUAN3D__MODEL__DEVICE=auto

# ---- Ngrok ----
# HUNYUAN3D__NGROK__ENABLED=true
# HUNYUAN3D__NGROK__AUTHTOKEN=your_ngrok_token_here

# ---- HuggingFace (for gated models) ----
# HUGGINGFACE_TOKEN=hf_...
